rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /artifacts/{appId}/users/{userId}/{tournamentId}/{allPaths=**} {
      
      // 限制使用者僅能讀取自己的目錄，且必須登入
      allow read: if request.auth != null && request.auth.uid == userId;

      // 限制使用者上傳與更新檔案：限制檔案大小為 10MB 以下，且限定圖片與 PDF 格式
      allow create, update: if request.auth != null 
                            && request.auth.uid == userId
                            && request.resource.size < 10 * 1024 * 1024 
                            && request.resource.contentType.matches('image/.*|application/pdf');

      // 允許使用者刪除自己的檔案（前端介面上應有對應的狀態鎖定）
      allow delete: if request.auth != null && request.auth.uid == userId;
      
      // 允許系統管理員、以及有權限的局部管理員讀取以利審核（保留 Email 直接判斷）
      allow read: if request.auth != null && (
        request.auth.token.admin == true || 
        request.auth.token.email == "chao82465@gmail.com" ||
        (request.auth.token.scopedAdmin != null && 
          request.auth.token.scopedAdmin.type == 'tournament' && 
          request.auth.token.scopedAdmin.value == tournamentId
        )
      );
    }
  }
}
